@page
@model ForgotPasswordConfirmation
@{
    ViewData["Title"] = "Revisa tu correo";
}

<div class="login-page">
    <div class="login-card">
        <h1 class="font-xl mb-2">Revisa tu correo</h1>
        <p class="text-muted mb-6">
            Si el correo que ingresaste está registrado, te enviamos un enlace con instrucciones para restablecer tu contraseña.
        </p>

        <div class="flex-col gap-2 mt-4">
            <a asp-page="./Login" class="table-link-manage">Volver a iniciar sesión</a>
        </div>
    </div>
</div>