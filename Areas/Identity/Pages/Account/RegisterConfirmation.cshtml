@page
@model RegisterConfirmationModel
@{
    ViewData["Title"] = "Confirma tu cuenta";
}

<div class="login-page">
    <div class="login-card">
        <h1 class="font-xl mb-2">Confirma tu cuenta</h1>
        <p class="text-muted mb-6">
            Te enviamos un correo a <strong>@Model.Email</strong> con un enlace para confirmar tu cuenta. Revisa tu bandeja de entrada para continuar.
        </p>

        <div class="flex-col gap-2 mt-4">
            <a asp-page="./Login" class="table-link-manage">Volver a iniciar sesión</a>
        </div>
    </div>
</div>