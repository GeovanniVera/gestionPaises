@page
@model RegisterModel
@{
    ViewData["Title"] = "Crear cuenta";
}

<div class="login-page">
    <div class="login-card">
        <h1 class="font-xl mb-2">Crear cuenta</h1>
        <p class="text-muted mb-6">Regístrate en el Sistema de Gestión de Países</p>

        <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <div class="field-group">
                <label asp-for="Input.Email" class="input-label">Correo electrónico</label>
                <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="nombre@ejemplo.com" />
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>

            <div class="field-group">
                <label asp-for="Input.Password" class="input-label">Contraseña</label>
                <input asp-for="Input.Password" class="form-control" autocomplete="new-password" aria-required="true" placeholder="Contraseña" />
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>

            <div class="field-group">
                <label asp-for="Input.ConfirmPassword" class="input-label">Confirmar contraseña</label>
                <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" aria-required="true" placeholder="Confirmar contraseña" />
                <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
            </div>

            <div class="form-actions">
                <button id="registerSubmit" type="submit" class="btn btn-primary w-full">Crear cuenta</button>
            </div>

            <div class="flex-col gap-2 mt-4">
                <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl" class="table-link-manage">¿Ya tienes cuenta? Inicia sesión</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}