@page
@model AccessDeniedModel
@{
    ViewData["Title"] = "Acceso denegado";
}

<div class="login-page">
    <div class="login-card">
        <h1 class="font-xl mb-2" style="color: var(--danger);">Acceso denegado</h1>
        <p class="text-muted mb-6">
            No tienes permisos suficientes para acceder a este recurso. Si crees que esto es un error, contacta a un administrador del sistema.
        </p>

        <div class="flex-col gap-2 mt-4">
            <a asp-controller="Home" asp-action="Index" class="table-link-manage">Volver al inicio</a>
        </div>
    </div>
</div>