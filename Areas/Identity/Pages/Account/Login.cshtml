@page
@model LoginModel

@{
    ViewData["Title"] = "Iniciar sesión";
}

<div class="login-page">
    <div class="login-card">
        <h1 class="font-xl mb-2">Iniciar sesión</h1>
        <p class="text-muted mb-6">Accede al Sistema de Gestión de Países</p>

        <form id="account" method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <div class="field-group">
                <label asp-for="Input.Email" class="input-label">Correo electrónico</label>
                <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="nombre@ejemplo.com" />
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>

            <div class="field-group">
                <label asp-for="Input.Password" class="input-label">Contraseña</label>
                <input asp-for="Input.Password" class="form-control" autocomplete="current-password" aria-required="true" placeholder="Contraseña" />
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>

            <div class="flex align-center gap-2 mb-4">
                <input class="form-check-input" asp-for="Input.RememberMe" />
                <label asp-for="Input.RememberMe">@Html.DisplayNameFor(m => m.Input.RememberMe)</label>
            </div>

            <div class="form-actions">
                <button id="login-submit" type="submit" class="btn btn-primary w-full">Iniciar sesión</button>
            </div>

            <div class="flex-col gap-2 mt-4">
                <a id="forgot-password" asp-page="./ForgotPassword" class="text-muted">¿Olvidaste tu contraseña?</a>
                <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="table-link-manage">Crear una cuenta nueva</a>
                <a id="resend-confirmation" asp-page="./ResendEmailConfirmation" class="text-muted">Reenviar confirmación de correo</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}