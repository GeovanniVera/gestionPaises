@page
@model ResetPasswordConfirmationModel
@{
    ViewData["Title"] = "Contraseña restablecida";
}

<div class="login-page">
    <div class="login-card">
        <h1 class="font-xl mb-2">Contraseña restablecida</h1>
        <p class="text-muted mb-6">Tu contraseña se actualizó correctamente.</p>

        <div class="flex-col gap-2 mt-4">
            <a asp-page="./Login" class="table-link-manage">Iniciar sesión</a>
        </div>
    </div>
</div>