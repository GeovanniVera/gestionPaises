@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = "Recuperar contraseña";
}

<div class="login-page">
    <div class="login-card">
        <h1 class="font-xl mb-2">Recuperar contraseña</h1>
        <p class="text-muted mb-6">Ingresa tu correo y te enviaremos instrucciones para restablecerla</p>

        <form method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <div class="field-group">
                <label asp-for="Input.Email" class="input-label">Correo electrónico</label>
                <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="nombre@ejemplo.com" />
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary w-full">Enviar enlace de recuperación</button>
            </div>

            <div class="flex-col gap-2 mt-4">
                <a asp-page="./Login" class="table-link-manage">Volver a iniciar sesión</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}