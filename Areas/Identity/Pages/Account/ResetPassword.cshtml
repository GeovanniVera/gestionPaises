@page
@model ResetPasswordModel
@{
    ViewData["Title"] = "Restablecer contraseña";
}

<div class="login-page">
    <div class="login-card">
        <h1 class="font-xl mb-2">Restablecer contraseña</h1>
        <p class="text-muted mb-6">Ingresa tu nueva contraseña</p>

        <form method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
            <input asp-for="Input.Code" type="hidden" />

            <div class="field-group">
                <label asp-for="Input.Email" class="input-label">Correo electrónico</label>
                <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="nombre@ejemplo.com" />
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>

            <div class="field-group">
                <label asp-for="Input.Password" class="input-label">Nueva contraseña</label>
                <input asp-for="Input.Password" class="form-control" autocomplete="new-password" aria-required="true" placeholder="Ingresa tu nueva contraseña" />
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>

            <div class="field-group">
                <label asp-for="Input.ConfirmPassword" class="input-label">Confirmar contraseña</label>
                <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" aria-required="true" placeholder="Confirma tu nueva contraseña" />
                <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary w-full">Restablecer contraseña</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}