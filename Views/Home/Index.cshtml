@using Microsoft.AspNetCore.Identity
@using gestionpaises.Models
@inject SignInManager<ApplicationUser> SignInManager

@{
    ViewData["Title"] = SignInManager.IsSignedIn(User) ? "Dashboard" : "Inicio";
}

@if (SignInManager.IsSignedIn(User))
{
    <div class="home-hero">
        <h1 class="font-xxl" style="margin-bottom: 0.5rem;">Administración Global</h1>
        <p style="color: var(--ink-secondary); font-size: var(--font-base);">
            Bienvenido al sistema de administración y control de la base de datos de países, ciudades y lenguajes oficiales del ecosistema.
        </p>
    </div>

    <div class="stats-grid" style="margin-bottom: 2rem;">
        
        <div class="card">
            <div style="font-size: var(--font-sm); color: var(--ink-secondary); text-transform: uppercase; margin-bottom: 0.5rem;">Países Registrados</div>
            <h2 style="font-size: 2.25rem; font-weight: 700; color: var(--accent-primary);">@ViewBag.TotalCountries</h2>
        </div>

        <div class="card">
            <div style="font-size: var(--font-sm); color: var(--ink-secondary); text-transform: uppercase; margin-bottom: 0.5rem;">Ciudades Registradas</div>
            <h2 style="font-size: 2.25rem; font-weight: 700; color: #2a6b8f;">@ViewBag.TotalCities</h2>
        </div>

        <div class="card">
            <div style="font-size: var(--font-sm); color: var(--ink-secondary); text-transform: uppercase; margin-bottom: 0.5rem;">Lenguajes Registrados</div>
            <h2 style="font-size: 2.25rem; font-weight: 700; color: var(--success);">@ViewBag.TotalLanguages</h2>
        </div>

        <div class="card">
            <div style="font-size: var(--font-sm); color: var(--ink-secondary); text-transform: uppercase; margin-bottom: 0.5rem;">Seguridad de Sesiones</div>
            <h2 style="font-size: 1.5rem; font-weight: 700; color: var(--ink-primary);">Activa</h2>
            <div style="font-size: 12px; color: var(--success); margin-top: 0.5rem;">✓ Sin dobles inicios detectados</div>
        </div>

    </div>

    <div class="card">
        <h3 class="card-title">Configuración de Seguridad de Aplicaciones</h3>
        <p style="margin-bottom: 1.5rem;">
            Estado de las alertas criptográficas del cargador seguro de imágenes y archivos de banderas (IFormFile):
        </p>
        <div class="alert alert-success" style="margin-bottom: 0;">
            <span>✓</span>
            <span>El cargador de archivos valida correctamente las firmas mágicas de imagen para evitar la subida de scripts maliciosos.</span>
        </div>
    </div>
}
else
{
    <!-- Welcome Hero -->
    <div style="text-align: center; padding: 4rem 1rem; border-bottom: 1px solid var(--border-color); max-width: 800px; margin: 0 auto;">
        <h1 class="font-xxl" style="margin-bottom: 1.5rem; font-family: var(--font-display); font-weight: 700;">Consola de Mantenimiento Global</h1>
        <p style="color: var(--ink-secondary); font-size: var(--font-lg); margin-bottom: 2.5rem; max-width: 600px; margin-left: auto; margin-right: auto; line-height: 1.6;">
            Acceda al sistema de administración territorial del ecosistema para gestionar registros de países, ciudades y lenguajes oficiales.
        </p>
        <div style="display: flex; gap: 1rem; justify-content: center;">
            <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-primary" style="padding: 12px 28px;">
                Acceder al Sistema
            </a>
            <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-secondary" style="padding: 12px 28px;">
                Crear Cuenta
            </a>
        </div>
    </div>

    <!-- Feature Grid -->
    <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; margin-top: 4rem; max-width: 1000px; margin-left: auto; margin-right: auto;">
        <div class="card" style="padding: 2rem; text-align: center;">
            <div style="width: 48px; height: 48px; border-radius: 50%; background: var(--accent-light); color: var(--accent-primary); display: flex; align-items: center; justify-content: center; margin: 0 auto 1.25rem; font-weight: bold; font-family: var(--font-display); font-size: 0.95rem; letter-spacing: 0.5px;">MAP</div>
            <h3 style="font-size: 1.25rem; font-weight: 600; margin-bottom: 0.75rem;">Control de Países</h3>
            <p style="color: var(--ink-secondary); font-size: var(--font-sm); line-height: 1.5;">
                Gestión avanzada de registros nacionales, superficies territoriales, gobierno y jefes de estado.
            </p>
        </div>
        <div class="card" style="padding: 2rem; text-align: center;">
            <div style="width: 48px; height: 48px; border-radius: 50%; background: rgba(42, 107, 143, 0.08); color: #2a6b8f; display: flex; align-items: center; justify-content: center; margin: 0 auto 1.25rem; font-weight: bold; font-family: var(--font-display); font-size: 0.95rem; letter-spacing: 0.5px;">URB</div>
            <h3 style="font-size: 1.25rem; font-weight: 600; margin-bottom: 0.75rem;">Ciudades y Distritos</h3>
            <p style="color: var(--ink-secondary); font-size: var(--font-sm); line-height: 1.5;">
                Catálogo detallado de metrópolis, poblaciones urbanas y distritos gubernamentales.
            </p>
        </div>
        <div class="card" style="padding: 2rem; text-align: center;">
            <div style="width: 48px; height: 48px; border-radius: 50%; background: rgba(59, 110, 79, 0.08); color: var(--success); display: flex; align-items: center; justify-content: center; margin: 0 auto 1.25rem; font-weight: bold; font-family: var(--font-display); font-size: 0.95rem; letter-spacing: 0.5px;">LNG</div>
            <h3 style="font-size: 1.25rem; font-weight: 600; margin-bottom: 0.75rem;">Lenguajes Oficiales</h3>
            <p style="color: var(--ink-secondary); font-size: var(--font-sm); line-height: 1.5;">
                Monitoreo y administración de idiomas maternos, porcentajes demográficos y estatus oficial.
            </p>
        </div>
    </div>
}
