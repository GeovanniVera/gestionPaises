@model IEnumerable<gestionpaises.Models.CountryLanguage>

@{
    ViewData["Title"] = "Lenguajes";
}

<div class="countries-header-actions">
    <div>
        <h2>Idiomas de Países</h2>
    </div>
    @if (User.IsInRole("Editor") || User.IsInRole("Administrador"))
    {
        <a asp-action="Create" class="btn btn-primary">
            + Agregar Lenguaje
        </a>
    }
</div>

<div class="table-responsive">
    <table class="table">
        <thead>
            <tr>
                <th>Código País</th>
                <th>Idioma / Lenguaje</th>
                <th>Oficial</th>
                <th>Porcentaje</th>
                <th>Mantenimiento</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="5" style="text-align: center; color: var(--ink-secondary); padding: 2.5rem; font-style: italic;">No hay datos que mostrar.</td>
                </tr>
            }
            @foreach (var item in Model)
            {
                <tr>
                    <td><strong>@item.CountryCode</strong></td>
                    <td>@item.Language</td>
                    <td>
                        @if (item.IsOfficial)
                        {
                            <span class="badge badge-success">T</span>
                        }
                        else
                        {
                            <span class="badge badge-danger">F</span>
                        }
                    </td>
                    <td>@item.Percentage.ToString("F1")%</td>
                    <td>
                        <a asp-action="Details" asp-route-countryCode="@item.CountryCode" asp-route-language="@item.Language" class="table-link-manage">Ver</a>
                        @if (User.IsInRole("Editor") || User.IsInRole("Administrador"))
                        {
                            <span style="color: var(--border-color); margin: 0 4px;">|</span>
                            <a asp-action="Edit" asp-route-countryCode="@item.CountryCode" asp-route-language="@item.Language" class="table-link-manage">Editar</a>
                        }
                        @if (User.IsInRole("Administrador"))
                        {
                            <span style="color: var(--border-color); margin: 0 4px;">|</span>
                            <a asp-action="Delete" asp-route-countryCode="@item.CountryCode" asp-route-language="@item.Language" class="table-link-drop">Drop</a>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>