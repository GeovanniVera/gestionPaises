@model gestionpaises.Models.CountryLanguage

@{
    ViewData["Title"] = "Agregar idioma";
}

<div class="dashboard-header" style="margin-bottom: 2rem; max-width: 600px; margin: 0 auto 2rem auto;">
    <h2>Agregar Idioma a un País</h2>
</div>

<div class="card" style="padding: 2.5rem; max-width: 600px; margin: 0 auto; box-shadow: 0 10px 25px rgba(20, 33, 61, 0.05); border: 1px solid var(--border-color);">
    <form asp-action="Create" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger" style="margin-bottom: 1.5rem;"></div>

        <div class="form-grid" style="display: grid; grid-template-columns: repeat(12, 1fr); gap: 1.25rem;">
            
            <div style="grid-column: span 12;">
                <label asp-for="CountryCode" class="form-label" style="font-weight: 500; font-size: 13px; color: var(--ink-secondary); display: block; margin-bottom: 6px;">País</label>
                <select asp-for="CountryCode" class="form-select" asp-items="ViewBag.Countries" style="width: 100%; padding: 12px 16px; border-radius: var(--border-radius-md); border: 1px solid var(--border-color); background-color: var(--bg-secondary); color: var(--ink-primary);">
                    <option value="">-- Selecciona un país --</option>
                </select>
                <span asp-validation-for="CountryCode" class="text-danger" style="font-size: 12px;"></span>
            </div>

            <div style="grid-column: span 12;">
                <label asp-for="Language" class="form-label" style="font-weight: 500; font-size: 13px; color: var(--ink-secondary); display: block; margin-bottom: 6px;">Idioma</label>
                <input asp-for="Language" class="form-control" placeholder="Ej. Español" style="width: 100%;" />
                <span asp-validation-for="Language" class="text-danger" style="font-size: 12px;"></span>
            </div>

            <div style="grid-column: span 6; display: flex; align-items: center; margin-top: 1rem;">
                <div class="form-check" style="display: flex; align-items: center; gap: 8px;">
                    <input asp-for="IsOfficial" class="form-check-input" style="width: 18px; height: 18px; cursor: pointer; accent-color: var(--accent-primary);" />
                    <label asp-for="IsOfficial" class="form-check-label" style="font-weight: 500; font-size: 14px; cursor: pointer; color: var(--ink-primary);">Es idioma oficial</label>
                </div>
            </div>

            <div style="grid-column: span 6;">
                <label asp-for="Percentage" class="form-label" style="font-weight: 500; font-size: 13px; color: var(--ink-secondary); display: block; margin-bottom: 6px;">Porcentaje de hablantes (%)</label>
                <input asp-for="Percentage" class="form-control" type="number" step="0.1" placeholder="Ej. 92.5" style="width: 100%;" />
                <span asp-validation-for="Percentage" class="text-danger" style="font-size: 12px;"></span>
            </div>

        </div>

        <div style="display: flex; gap: 1rem; justify-content: flex-end; margin-top: 2.5rem; border-top: 1px solid var(--border-color); padding-top: 1.5rem;">
            <a asp-action="Index" class="btn btn-secondary" style="padding: 10px 24px; border-radius: var(--border-radius-md);">Cancelar</a>
            <button type="submit" class="btn btn-primary" style="padding: 10px 32px; border-radius: var(--border-radius-md); background-color: var(--accent-primary); color: #fff; font-weight: 600;">Guardar</button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}