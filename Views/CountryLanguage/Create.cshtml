@model gestionpaises.Models.CountryLanguage

@{
    ViewData["Title"] = "Agregar idioma";
}

<h1>Agregar idioma</h1>

<form asp-action="Create" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="form-group mb-3">
        <label asp-for="CountryCode" class="form-label">País</label>
        <select asp-for="CountryCode" class="form-select" asp-items="ViewBag.Countries">
            <option value="">-- Selecciona un país --</option>
        </select>
        <span asp-validation-for="CountryCode" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="Language" class="form-label">Idioma</label>
        <input asp-for="Language" class="form-control" placeholder="Ej. Español" />
        <span asp-validation-for="Language" class="text-danger"></span>
    </div>

    <div class="form-check mb-3">
        <input asp-for="IsOfficial" class="form-check-input" />
        <label asp-for="IsOfficial" class="form-check-label">Es idioma oficial</label>
    </div>

    <div class="form-group mb-3">
        <label asp-for="Percentage" class="form-label">Porcentaje de hablantes</label>
        <input asp-for="Percentage" class="form-control" type="number" step="0.1" />
        <span asp-validation-for="Percentage" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Guardar</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>