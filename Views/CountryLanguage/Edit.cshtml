@model gestionpaises.Models.CountryLanguage

@{
    ViewData["Title"] = "Editar idioma";
}

<h1>Editar idioma</h1>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="CountryCode" />
    <input type="hidden" asp-for="Language" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="form-group mb-3">
        <label class="form-label">País</label>
        <input value="@Model.Country?.Name" class="form-control" disabled />
    </div>

    <div class="form-group mb-3">
        <label class="form-label">Idioma</label>
        <input value="@Model.Language" class="form-control" disabled />
    </div>

    <div class="form-check mb-3">
        <input asp-for="IsOfficial" class="form-check-input" />
        <label asp-for="IsOfficial" class="form-check-label">Es idioma oficial</label>
    </div>

    <div class="form-group mb-3">
        <label asp-for="Percentage" class="form-label">Porcentaje de hablantes</label>
        <input asp-for="Percentage" class="form-control" />
        <span asp-validation-for="Percentage" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Guardar cambios</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>