@model gestionpaises.Models.Country

@{
    ViewData["Title"] = "Crear país";
}

<div class="dashboard-header" style="margin-bottom: 2rem; max-width: 900px; margin: 0 auto 2rem auto;">
    <h2>Crear Nuevo País</h2>
</div>

<div class="card" style="padding: 2.5rem; max-width: 900px; margin: 0 auto; box-shadow: 0 10px 25px rgba(20, 33, 61, 0.05); border: 1px solid var(--border-color);">
    <form asp-action="Create" method="post" enctype="multipart/form-data">
        <div asp-validation-summary="ModelOnly" class="text-danger" style="margin-bottom: 1.5rem;"></div>

        <div class="form-grid" style="display: grid; grid-template-columns: repeat(12, 1fr); gap: 1.25rem;">

            <div style="grid-column: span 12; margin-bottom: 0.5rem;">
                <h3 style="font-size: 1.15rem; font-family: var(--font-display); font-weight: 600; color: var(--ink-primary); margin: 0; padding-bottom: 0.5rem; border-bottom: 1px solid var(--border-color);">Información General</h3>
            </div>

            <div style="grid-column: span 4;">
                <label asp-for="Code" class="form-label" style="font-weight: 500; font-size: 13px; color: var(--ink-secondary); display: block; margin-bottom: 6px;">Código (3 letras)</label>
                <input asp-for="Code" class="form-control" maxlength="3" placeholder="Ej. MEX" style="width: 100%; text-transform: uppercase;" />
                <span asp-validation-for="Code" class="text-danger" style="font-size: 12px;"></span>
            </div>
            <div style="grid-column: span 8;">
                <label asp-for="Name" class="form-label" style="font-weight: 500; font-size: 13px; color: var(--ink-secondary); display: block; margin-bottom: 6px;">Nombre del País</label>
                <input asp-for="Name" class="form-control" placeholder="Ej. México" style="width: 100%;" />
                <span asp-validation-for="Name" class="text-danger" style="font-size: 12px;"></span>
            </div>

            <div style="grid-column: span 6;">
                <label asp-for="Continent" class="form-label" style="font-weight: 500; font-size: 13px; color: var(--ink-secondary); display: block; margin-bottom: 6px;">Continente</label>
                <select asp-for="Continent" class="form-select">
                    <option value="Asia">Asia</option>
                    <option value="Europe">Europa</option>
                    <option value="North America">América del Norte</option>
                    <option value="Africa">África</option>
                    <option value="Oceania">Oceanía</option>
                    <option value="Antarctica">Antártida</option>
                    <option value="South America">América del Sur</option>
                </select>
                <span asp-validation-for="Continent" class="text-danger" style="font-size: 12px;"></span>
            </div>
            <div style="grid-column: span 6;">
                <label asp-for="Region" class="form-label" style="font-weight: 500; font-size: 13px; color: var(--ink-secondary); display: block; margin-bottom: 6px;">Región Geográfica</label>
                <select asp-for="Region" class="form-select" style="width: 100%;">
                    <option value="">-- Selecciona una región --</option>
                    <option value="Western Europe">Europa Occidental</option>
                    <option value="Eastern Europe">Europa Oriental</option>
                    <option value="Southern Europe">Europa del Sur</option>
                    <option value="Nordic Countries">Países Nórdicos</option>
                    <option value="North America">América del Norte</option>
                    <option value="Central America">América Central</option>
                    <option value="South America">América del Sur</option>
                    <option value="Caribbean">El Caribe</option>
                </select>
                <span asp-validation-for="Region" class="text-danger" style="font-size: 12px;"></span>
            </div>

            <div style="grid-column: span 12; margin: 1rem 0 0.5rem 0;">
                <h3 style="font-size: 1.15rem; font-family: var(--font-display); font-weight: 600; color: var(--ink-primary); margin: 0; padding-bottom: 0.5rem; border-bottom: 1px solid var(--border-color);">Demografía y Geografía</h3>
            </div>

            <div style="grid-column: span 4;">
                <label asp-for="SurfaceArea" class="form-label" style="font-weight: 500; font-size: 13px; color: var(--ink-secondary); display: block; margin-bottom: 6px;">Superficie Territorial (km²)</label>
                <input asp-for="SurfaceArea" class="form-control" type="number" step="0.01" asp-format="{0:0.00}" placeholder="Ej. 1958201.00" style="width: 100%;" />
                <span asp-validation-for="SurfaceArea" class="text-danger" style="font-size: 12px;"></span>
            </div>
            <div style="grid-column: span 4;">
                <label asp-for="Population" class="form-label" style="font-weight: 500; font-size: 13px; color: var(--ink-secondary); display: block; margin-bottom: 6px;">Población</label>
                <input asp-for="Population" class="form-control" type="number" placeholder="Ej. 126000000" style="width: 100%;" />
                <span asp-validation-for="Population" class="text-danger" style="font-size: 12px;"></span>
            </div>
            <div style="grid-column: span 4;">
                <label asp-for="LifeExpectancy" class="form-label" style="font-weight: 500; font-size: 13px; color: var(--ink-secondary); display: block; margin-bottom: 6px;">Expectativa de Vida (Años)</label>
                <input asp-for="LifeExpectancy" class="form-control" type="number" step="0.1" asp-format="{0:0.0}" placeholder="Ej. 71.5" style="width: 100%;" />
                <span asp-validation-for="LifeExpectancy" class="text-danger" style="font-size: 12px;"></span>
            </div>

            <div style="grid-column: span 4;">
                <label asp-for="IndepYear" class="form-label" style="font-weight: 500; font-size: 13px; color: var(--ink-secondary); display: block; margin-bottom: 6px;">Año de Independencia</label>
                <input asp-for="IndepYear" class="form-control" type="number" placeholder="Ej. 1810" style="width: 100%;" />
                <span asp-validation-for="IndepYear" class="text-danger" style="font-size: 12px;"></span>
            </div>
            <div style="grid-column: span 8;">
                <label asp-for="LocalName" class="form-label" style="font-weight: 500; font-size: 13px; color: var(--ink-secondary); display: block; margin-bottom: 6px;">Nombre Local</label>
                <input asp-for="LocalName" class="form-control" placeholder="Ej. México" style="width: 100%;" />
                <span asp-validation-for="LocalName" class="text-danger" style="font-size: 12px;"></span>
            </div>

            <div style="grid-column: span 12; margin: 1rem 0 0.5rem 0;">
                <h3 style="font-size: 1.15rem; font-family: var(--font-display); font-weight: 600; color: var(--ink-primary); margin: 0; padding-bottom: 0.5rem; border-bottom: 1px solid var(--border-color);">Economía y Gobierno</h3>
            </div>

            <div style="grid-column: span 6;">
                <label asp-for="GNP" class="form-label" style="font-weight: 500; font-size: 13px; color: var(--ink-secondary); display: block; margin-bottom: 6px;">Producto Nacional Bruto (GNP - USD)</label>
                <input asp-for="GNP" class="form-control" type="text" pattern="[0-9]+([\.,][0-9]+)?" asp-format="{0:0.00}" placeholder="Ej. 765000000000" style="width: 100%;" />
                <span asp-validation-for="GNP" class="text-danger" style="font-size: 12px;"></span>
            </div>
            <div style="grid-column: span 6;">
                <label asp-for="GNPOld" class="form-label" style="font-weight: 500; font-size: 13px; color: var(--ink-secondary); display: block; margin-bottom: 6px;">GNP Anterior (USD)</label>
                <input asp-for="GNPOld" class="form-control" type="text" pattern="[0-9]+([\.,][0-9]+)?" asp-format="{0:0.00}" placeholder="Opcional" style="width: 100%;" />
                <span asp-validation-for="GNPOld" class="text-danger" style="font-size: 12px;"></span>
            </div>

            <div style="grid-column: span 6;">
                <label asp-for="GovernmentForm" class="form-label" style="font-weight: 500; font-size: 13px; color: var(--ink-secondary); display: block; margin-bottom: 6px;">Forma de Gobierno</label>
                <select asp-for="GovernmentForm" class="form-select" style="width: 100%;">
                    <option value="">-- Selecciona una forma --</option>
                    <option value="Republic">República</option>
                    <option value="Federal Republic">República Federal</option>
                    <option value="Constitutional Monarchy">Monarquía Constitucional</option>
                    <option value="Federal Monarchy">Monarquía Federal</option>
                    <option value="Absolute Monarchy">Monarquía Absoluta</option>
                    <option value="Territory">Territorio / Dependencia</option>
                </select>
                <span asp-validation-for="GovernmentForm" class="text-danger" style="font-size: 12px;"></span>
            </div>
            <div style="grid-column: span 6;">
                <label asp-for="HeadOfState" class="form-label" style="font-weight: 500; font-size: 13px; color: var(--ink-secondary); display: block; margin-bottom: 6px;">Jefe de Estado</label>
                <input asp-for="HeadOfState" class="form-control" placeholder="Ej. Andrés Manuel López Obrador" style="width: 100%;" />
                <span asp-validation-for="HeadOfState" class="text-danger" style="font-size: 12px;"></span>
            </div>

            <div style="grid-column: span 12; margin: 1rem 0 0.5rem 0;">
                <h3 style="font-size: 1.15rem; font-family: var(--font-display); font-weight: 600; color: var(--ink-primary); margin: 0; padding-bottom: 0.5rem; border-bottom: 1px solid var(--border-color);">Configuración Adicional</h3>
            </div>

            <div style="grid-column: span 6;">
                <label asp-for="Capital" class="form-label" style="font-weight: 500; font-size: 13px; color: var(--ink-secondary); display: block; margin-bottom: 6px;">Ciudad Capital</label>
                <select asp-for="Capital" class="form-select" asp-items="ViewBag.Capital">
                    <option value="">-- Sin asignar / Ninguna --</option>
                </select>
                <span asp-validation-for="Capital" class="text-danger" style="font-size: 12px;"></span>
                <small class="form-text text-muted d-block mt-1" style="font-size: 11px; line-height: 1.3;">
                    Si no hay ciudades registradas para este país aún, puedes dejarlo en blanco y asignarlo editando el país después.
                </small>
            </div>
            <div style="grid-column: span 6;">
                <label asp-for="Code2" class="form-label" style="font-weight: 500; font-size: 13px; color: var(--ink-secondary); display: block; margin-bottom: 6px;">Código Alternativo (2 letras)</label>
                <input asp-for="Code2" class="form-control" maxlength="2" placeholder="Ej. MX" style="width: 100%; text-transform: uppercase;" />
                <span asp-validation-for="Code2" class="text-danger" style="font-size: 12px;"></span>
            </div>

            <div style="grid-column: span 12; margin-top: 0.5rem;">
                <label for="bandera" class="form-label" style="font-weight: 500; font-size: 13px; color: var(--ink-secondary); display: block; margin-bottom: 6px;">Bandera del país</label>
                <input type="file" name="bandera" id="bandera" class="form-control" accept=".jpg,.jpeg,.png,.gif" style="width: 100%;" />
                <span class="text-danger" style="font-size: 12px;">@((ViewData.ModelState["BanderaPath"]?.Errors.Count > 0) ? ViewData.ModelState["BanderaPath"]?.Errors[0].ErrorMessage : "")</span>
            </div>

        </div>

        <div style="display: flex; gap: 1rem; justify-content: flex-end; margin-top: 2.5rem; border-top: 1px solid var(--border-color); padding-top: 1.5rem;">
            <a asp-action="Index" class="btn btn-secondary" style="padding: 10px 24px; border-radius: var(--border-radius-md);">Cancelar</a>
            <button type="submit" class="btn btn-primary" style="padding: 10px 32px; border-radius: var(--border-radius-md); background-color: var(--accent-primary); color: #fff; font-weight: 600;">Guardar</button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}