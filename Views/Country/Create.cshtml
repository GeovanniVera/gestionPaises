@model gestionpaises.Models.Country

@{
    ViewData["Title"] = "Crear país";
}

<h1>Crear país</h1>

<form asp-action="Create" method="post" enctype="multipart/form-data">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="form-group mb-3">
        <label asp-for="Code" class="form-label">Código (3 letras)</label>
        <input asp-for="Code" class="form-control" maxlength="3" placeholder="Ej. MEX" />
        <span asp-validation-for="Code" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="Name" class="form-label">Nombre del País</label>
        <input asp-for="Name" class="form-control" placeholder="Ej. México" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="Continent" class="form-label">Continente</label>
        <select asp-for="Continent" class="form-select">
            <option value="Asia">Asia</option>
            <option value="Europe">Europa</option>
            <option value="North America">América del Norte</option>
            <option value="Africa">África</option>
            <option value="Oceania">Oceanía</option>
            <option value="Antarctica">Antártida</option>
            <option value="South America">América del Sur</option>
        </select>
        <span asp-validation-for="Continent" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="Region" class="form-label">Región Geográfica</label>
        <input asp-for="Region" class="form-control" placeholder="Ej. Central America" />
        <span asp-validation-for="Region" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="Population" class="form-label">Población</label>
        <input asp-for="Population" class="form-control" type="number" />
        <span asp-validation-for="Population" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="LocalName" class="form-label">Nombre Local</label>
        <input asp-for="LocalName" class="form-control" placeholder="Ej. México" />
        <span asp-validation-for="LocalName" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="GovernmentForm" class="form-label">Forma de Gobierno</label>
        <input asp-for="GovernmentForm" class="form-control" placeholder="Ej. Federal Republic" />
        <span asp-validation-for="GovernmentForm" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="Code2" class="form-label">Código Alternativo (2 letras)</label>
        <input asp-for="Code2" class="form-control" maxlength="2" placeholder="Ej. MX" />
        <span asp-validation-for="Code2" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label for="bandera" class="form-label">Bandera del país</label>
        <input type="file" name="bandera" id="bandera" class="form-control" accept=".jpg,.jpeg,.png,.gif" />
        <span class="text-danger">@ViewData.ModelState["BanderaPath"]?.Errors.FirstOrDefault()?.ErrorMessage</span>
    </div>

    <button type="submit" class="btn btn-primary">Guardar</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>