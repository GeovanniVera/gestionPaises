@model IEnumerable<gestionpaises.Models.Country>

@{
    ViewData["Title"] = "Países";

    string TraducirContinente(string continent)
    {
        return continent switch
        {
            "Asia" => "Asia",
            "Europe" => "Europa",
            "North America" => "América del Norte",
            "Africa" => "África",
            "Oceania" => "Oceanía",
            "Antarctica" => "Antártida",
            "South America" => "América del Sur",
            _ => continent
        };
    }
}

<div class="countries-header-actions">
    <div>
        <h2>Administración de Países</h2>
    </div>
    @if (User.IsInRole("Editor") || User.IsInRole("Administrador"))
    {
        <a asp-action="Create" class="btn btn-primary">
            + Agregar País
        </a>
    }
</div>

<div class="table-responsive">
    <table class="table">
        <thead>
            <tr>
                <th style="width: 60px;">Bandera</th>
                <th>Código</th>
                <th>Nombre</th>
                <th>Continente</th>
                <th>Región</th>
                <th>Población</th>
                <th>Mantenimiento</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="7" style="text-align: center; color: var(--ink-secondary); padding: 2.5rem; font-style: italic;">No hay datos que mostrar.</td>
                </tr>
            }
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        @{
                            var rowFlagUrl = "";
                            if (!string.IsNullOrEmpty(item.BanderaPath))
                            {
                                rowFlagUrl = item.BanderaPath.StartsWith("wwwroot") 
                                    ? item.BanderaPath.Substring("wwwroot".Length) 
                                    : item.BanderaPath;
                                rowFlagUrl = rowFlagUrl.Replace("\\", "/");
                                if (!rowFlagUrl.Contains("/"))
                                {
                                    rowFlagUrl = "/uploads/banderas/" + rowFlagUrl;
                                }
                                if (!rowFlagUrl.StartsWith("/"))
                                {
                                    rowFlagUrl = "/" + rowFlagUrl;
                                }
                            }
                        }
                        <div style="border: 1px solid var(--border-color); border-radius: 4px; width: 36px; height: 24px; display: flex; align-items: center; justify-content: center; overflow: hidden; background: var(--bg-primary);">
                            @if (!string.IsNullOrEmpty(rowFlagUrl))
                            {
                                <img src="@rowFlagUrl" alt="" style="max-width: 100%; max-height: 100%; object-fit: contain;" onerror="handleFlagError(this, 'sm');" />
                            }
                            else
                            {
                                <img src="data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='36' height='24' viewBox='0 0 36 24'><rect width='100%' height='100%' fill='%23edeae4'/><text x='50%' y='55%' font-family='sans-serif' font-size='8' fill='%238d8a80' text-anchor='middle' dominant-baseline='middle'>N/D</text></svg>" alt="" style="max-width: 100%; max-height: 100%; object-fit: contain;" />
                            }
                        </div>
                    </td>
                    <td><strong>@item.Code</strong></td>
                    <td>@item.Name</td>
                    <td>@TraducirContinente(item.Continent)</td>
                    <td>@item.Region</td>
                    <td>@item.Population.ToString("N0")</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@item.Code" class="table-link-manage">Ver</a>
                        @if (User.IsInRole("Editor") || User.IsInRole("Administrador"))
                        {
                            <span style="color: var(--border-color); margin: 0 4px;">|</span>
                            <a asp-action="Edit" asp-route-id="@item.Code" class="table-link-manage">Editar</a>
                        }
                        @if (User.IsInRole("Administrador"))
                        {
                            <span style="color: var(--border-color); margin: 0 4px;">|</span>
                            <a asp-action="Delete" asp-route-id="@item.Code" class="table-link-drop">Drop</a>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>