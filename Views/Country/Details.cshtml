@model gestionpaises.Models.Country

@{
    ViewData["Title"] = "Detalle del país";
}

<h1>@Model.Name</h1>

<div class="row">
    <div class="col-md-6">
        <dl class="row">
            <dt class="col-sm-4">Código</dt>
            <dd class="col-sm-8">@Model.Code</dd>

            <dt class="col-sm-4">Continente</dt>
            <dd class="col-sm-8">@Model.Continent</dd>

            <dt class="col-sm-4">Región</dt>
            <dd class="col-sm-8">@Model.Region</dd>

            <dt class="col-sm-4">Población</dt>
            <dd class="col-sm-8">@Model.Population.ToString("N0")</dd>

            <dt class="col-sm-4">Esperanza de vida</dt>
            <dd class="col-sm-8">@Model.LifeExpectancy</dd>

            <dt class="col-sm-4">Forma de gobierno</dt>
            <dd class="col-sm-8">@Model.GovernmentForm</dd>
        </dl>
    </div>
</div>

<h3>Ciudades</h3>
<ul>
    @foreach (var city in Model.Cities)
    {
        <li>@city.Name (@city.Population.ToString("N0") hab.)</li>
    }
</ul>

<h3>Idiomas</h3>
<ul>
    @foreach (var lang in Model.CountryLanguages)
    {
        <li>@lang.Language @(lang.IsOfficial ? "(Oficial)" : "")</li>
    }
</ul>

<a asp-action="Index" class="btn btn-secondary">Volver al listado</a>