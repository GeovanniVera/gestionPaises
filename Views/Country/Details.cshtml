@model gestionpaises.Models.Country

@{
    ViewData["Title"] = "Detalle del país";
    var flagUrl = Url.Content("~/images/default-flag.png");
    if (Model != null)
    {
        if (!string.IsNullOrEmpty(Model.BanderaPath))
        {
            var tempPath = Model.BanderaPath.StartsWith("wwwroot") 
                ? Model.BanderaPath.Substring("wwwroot".Length) 
                : Model.BanderaPath;
            tempPath = tempPath.Replace("\\", "/");
            if (!tempPath.Contains("/") && !tempPath.Contains("\\"))
            {
                tempPath = "/uploads/banderas/" + tempPath;
            }
            if (!tempPath.StartsWith("/"))
            {
                tempPath = "/" + tempPath;
            }
            flagUrl = tempPath;
        }
    }

    string TraducirContinente(string continent)
    {
        return continent switch
        {
            "Asia" => "Asia",
            "Europe" => "Europa",
            "North America" => "América del Norte",
            "Africa" => "África",
            "Oceania" => "Oceanía",
            "Antarctica" => "Antártida",
            "South America" => "América del Sur",
            _ => continent
        };
    }

    var capitalCityName = Model?.Cities?.FirstOrDefault(c => c.ID == Model.Capital)?.Name ?? "N/D";
}

<div class="dashboard-header" style="margin-bottom: 2rem; max-width: 1000px; margin: 0 auto 2rem auto;">
    <h2>Ficha Técnica del País</h2>
</div>

<div class="card" style="padding: 2.5rem; max-width: 1000px; margin: 0 auto 2rem auto; box-shadow: 0 10px 25px rgba(20, 33, 61, 0.05); border: 1px solid var(--border-color);">
    
    <!-- Header: Nombre y Bandera -->
    <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 2px solid var(--border-color); padding-bottom: 1.5rem; margin-bottom: 2rem;">
        <div>
            <h1 style="font-size: 2.25rem; font-family: var(--font-display); font-weight: 700; color: var(--ink-primary); margin-bottom: 0.25rem;">@Model!.Name</h1>
            <p style="color: var(--accent-primary); font-weight: 600; font-size: 14px; margin: 0; display: flex; gap: 8px;">
                <span>Código Registro: <strong>@Model!.Code</strong></span>
                <span>•</span>
                <span>Código ISO: <strong>@Model!.Code2</strong></span>
            </p>
        </div>
        <div>
            <div style="border: 1px solid var(--border-color); border-radius: var(--border-radius-md); padding: 4px; background: var(--bg-primary); width: 140px; height: 90px; display: flex; align-items: center; justify-content: center; overflow: hidden; box-shadow: 0 4px 10px rgba(0,0,0,0.03);">
                <img src="@flagUrl" alt="Bandera de @Model!.Name" style="max-width: 100%; max-height: 100%; object-fit: contain;" />
            </div>
        </div>
    </div>

    <!-- Grid de Datos Técnicos -->
    <div class="form-grid" style="display: grid; grid-template-columns: repeat(12, 1fr); gap: 1.5rem; margin-bottom: 1rem;">
        
        <!-- Section: Geografía y Demografía -->
        <div style="grid-column: span 12; margin-bottom: -0.5rem;">
            <h4 style="font-size: 1rem; color: var(--accent-primary); text-transform: uppercase; letter-spacing: 0.05em; margin: 0; font-family: var(--font-display); font-weight: 700;">Datos Geográficos y Demografía</h4>
        </div>

        <div style="grid-column: span 4;">
            <span style="font-size: 11px; text-transform: uppercase; color: var(--ink-muted); display: block; margin-bottom: 4px; font-weight: 600;">Continente</span>
            <strong style="font-size: 1.15rem; color: var(--ink-primary);">@TraducirContinente(Model!.Continent)</strong>
        </div>
        <div style="grid-column: span 4;">
            <span style="font-size: 11px; text-transform: uppercase; color: var(--ink-muted); display: block; margin-bottom: 4px; font-weight: 600;">Región Geográfica</span>
            <strong style="font-size: 1.15rem; color: var(--ink-primary);">@Model!.Region</strong>
        </div>
        <div style="grid-column: span 4;">
            <span style="font-size: 11px; text-transform: uppercase; color: var(--ink-muted); display: block; margin-bottom: 4px; font-weight: 600;">Población</span>
            <strong style="font-size: 1.15rem; color: var(--ink-primary);">@Model!.Population.ToString("N0") hab.</strong>
        </div>

        <div style="grid-column: span 4;">
            <span style="font-size: 11px; text-transform: uppercase; color: var(--ink-muted); display: block; margin-bottom: 4px; font-weight: 600;">Superficie Territorial</span>
            <strong style="font-size: 1.15rem; color: var(--ink-primary);">@Model!.SurfaceArea.ToString("N2") km²</strong>
        </div>
        <div style="grid-column: span 4;">
            <span style="font-size: 11px; text-transform: uppercase; color: var(--ink-muted); display: block; margin-bottom: 4px; font-weight: 600;">Esperanza de Vida</span>
            <strong style="font-size: 1.15rem; color: var(--ink-primary);">@(Model!.LifeExpectancy.HasValue ? Model!.LifeExpectancy.Value.ToString("F1") + " Años" : "N/D")</strong>
        </div>
        <div style="grid-column: span 4;">
            <span style="font-size: 11px; text-transform: uppercase; color: var(--ink-muted); display: block; margin-bottom: 4px; font-weight: 600;">Año de Independencia</span>
            <strong style="font-size: 1.15rem; color: var(--ink-primary);">@(Model!.IndepYear.HasValue ? Model!.IndepYear.Value.ToString() : "N/D")</strong>
        </div>

        <!-- Section: Gobierno y Economía -->
        <div style="grid-column: span 12; margin: 1rem 0 -0.5rem 0; border-top: 1px solid var(--border-color); padding-top: 1.25rem;">
            <h4 style="font-size: 1rem; color: var(--accent-primary); text-transform: uppercase; letter-spacing: 0.05em; margin: 0; font-family: var(--font-display); font-weight: 700;">Gobierno y Economía</h4>
        </div>

        <div style="grid-column: span 4;">
            <span style="font-size: 11px; text-transform: uppercase; color: var(--ink-muted); display: block; margin-bottom: 4px; font-weight: 600;">Nombre Local</span>
            <strong style="font-size: 1.1rem; color: var(--ink-primary);">@Model!.LocalName</strong>
        </div>
        <div style="grid-column: span 4;">
            <span style="font-size: 11px; text-transform: uppercase; color: var(--ink-muted); display: block; margin-bottom: 4px; font-weight: 600;">Forma de Gobierno</span>
            <strong style="font-size: 1.1rem; color: var(--ink-primary);">@Model!.GovernmentForm</strong>
        </div>
        <div style="grid-column: span 4;">
            <span style="font-size: 11px; text-transform: uppercase; color: var(--ink-muted); display: block; margin-bottom: 4px; font-weight: 600;">Jefe de Estado</span>
            <strong style="font-size: 1.1rem; color: var(--ink-primary);">@(Model!.HeadOfState ?? "N/D")</strong>
        </div>

        <div style="grid-column: span 4;">
            <span style="font-size: 11px; text-transform: uppercase; color: var(--ink-muted); display: block; margin-bottom: 4px; font-weight: 600;">Producto Nacional Bruto (GNP)</span>
            <strong style="font-size: 1.15rem; color: var(--ink-primary);">@(Model!.GNP.HasValue ? "$" + Model!.GNP.Value.ToString("N2") + " USD" : "N/D")</strong>
        </div>
        <div style="grid-column: span 4;">
            <span style="font-size: 11px; text-transform: uppercase; color: var(--ink-muted); display: block; margin-bottom: 4px; font-weight: 600;">GNP Anterior</span>
            <strong style="font-size: 1.15rem; color: var(--ink-primary);">@(Model!.GNPOld.HasValue ? "$" + Model!.GNPOld.Value.ToString("N2") + " USD" : "N/D")</strong>
        </div>
        <div style="grid-column: span 4;">
            <span style="font-size: 11px; text-transform: uppercase; color: var(--ink-muted); display: block; margin-bottom: 4px; font-weight: 600;">Ciudad Capital</span>
            <strong style="font-size: 1.15rem; color: var(--accent-primary);"><span style="color: var(--ink-primary);">@capitalCityName</span></strong>
        </div>

    </div>
</div>

<!-- Grid de Ciudades y Lenguajes -->
<div style="display: grid; grid-template-columns: repeat(12, 1fr); gap: 2rem; max-width: 1000px; margin: 0 auto;">
    
    <!-- Card de Ciudades -->
    <div class="card" style="grid-column: span 6; padding: 2rem; box-shadow: 0 10px 25px rgba(20, 33, 61, 0.03); border: 1px solid var(--border-color); display: flex; flex-direction: column;">
        <h3 style="font-size: 1.25rem; font-family: var(--font-display); font-weight: 600; color: var(--ink-primary); margin-top: 0; margin-bottom: 1.25rem; padding-bottom: 0.5rem; border-bottom: 1px solid var(--border-color);">Ciudades Registradas</h3>
        
        @if (Model!.Cities == null || !Model.Cities.Any())
        {
            <div style="padding: 2rem 0; text-align: center; color: var(--ink-muted); font-style: italic;">
                No hay ciudades registradas.
            </div>
        }
        else
        {
            <div class="table-responsive" style="border: none; border-radius: 0; background: transparent;">
                <table class="table" style="font-size: 13px;">
                    <thead>
                        <tr style="background: transparent;">
                            <th style="padding: 10px 8px; font-size: 11px; background-color: var(--bg-primary);">Ciudad</th>
                            <th style="padding: 10px 8px; font-size: 11px; text-align: right; background-color: var(--bg-primary);">Población</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var city in Model.Cities)
                        {
                            <tr>
                                <td style="padding: 12px 8px;">
                                    <strong>@city.Name</strong>
                                    <span style="display: block; font-size: 11px; color: var(--ink-muted);">@city.District</span>
                                </td>
                                <td style="padding: 12px 8px; text-align: right; font-weight: 600;">@city.Population.ToString("N0")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>

    <!-- Card de Idiomas -->
    <div class="card" style="grid-column: span 6; padding: 2rem; box-shadow: 0 10px 25px rgba(20, 33, 61, 0.03); border: 1px solid var(--border-color); display: flex; flex-direction: column;">
        <h3 style="font-size: 1.25rem; font-family: var(--font-display); font-weight: 600; color: var(--ink-primary); margin-top: 0; margin-bottom: 1.25rem; padding-bottom: 0.5rem; border-bottom: 1px solid var(--border-color);">Idiomas y Demografía</h3>
        
        @if (Model!.CountryLanguages == null || !Model.CountryLanguages.Any())
        {
            <div style="padding: 2rem 0; text-align: center; color: var(--ink-muted); font-style: italic;">
                No hay idiomas registrados.
            </div>
        }
        else
        {
            <div class="table-responsive" style="border: none; border-radius: 0; background: transparent;">
                <table class="table" style="font-size: 13px;">
                    <thead>
                        <tr style="background: transparent;">
                            <th style="padding: 10px 8px; font-size: 11px; background-color: var(--bg-primary);">Idioma</th>
                            <th style="padding: 10px 8px; font-size: 11px; text-align: right; background-color: var(--bg-primary);">Porcentaje</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var lang in Model.CountryLanguages)
                        {
                            <tr>
                                <td style="padding: 12px 8px;">
                                    <strong>@lang.Language</strong>
                                    @if (lang.IsOfficial)
                                    {
                                        <span class="badge badge-success" style="font-size: 9px; padding: 2px 6px; margin-left: 6px;">Oficial</span>
                                    }
                                </td>
                                <td style="padding: 12px 8px; text-align: right; font-weight: 600;">@lang.Percentage.ToString("F1")%</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<div style="display: flex; justify-content: flex-end; max-width: 1000px; margin: 1.5rem auto 3rem auto; gap: 1rem;">
    <a asp-action="Index" class="btn btn-secondary" style="padding: 10px 24px; border-radius: var(--border-radius-md);">Volver al listado</a>
    <a asp-action="Edit" asp-route-id="@Model.Code" class="btn btn-primary" style="padding: 10px 32px; border-radius: var(--border-radius-md); background-color: var(--accent-primary); color: #fff; font-weight: 600;">Editar País</a>
</div>