@model gestionpaises.Models.Country

@{
    ViewData["Title"] = "Detalle del país";
    var flagUrl = "";
    if (Model != null)
    {
        if (!string.IsNullOrEmpty(Model.BanderaPath))
        {
            flagUrl = Model.BanderaPath.StartsWith("wwwroot") 
                ? Model.BanderaPath.Substring("wwwroot".Length) 
                : Model.BanderaPath;
            flagUrl = flagUrl.Replace("\\", "/");
            if (!flagUrl.Contains("/") && !flagUrl.Contains("\\"))
            {
                flagUrl = "/uploads/banderas/" + flagUrl;
            }
            if (!flagUrl.StartsWith("/"))
            {
                flagUrl = "/" + flagUrl;
            }
        }
    }

    string TraducirContinente(string continent)
    {
        return continent switch
        {
            "Asia" => "Asia",
            "Europe" => "Europa",
            "North America" => "América del Norte",
            "Africa" => "África",
            "Oceania" => "Oceanía",
            "Antarctica" => "Antártida",
            "South America" => "América del Sur",
            _ => continent
        };
    }
}

<div class="dashboard-header">
    <h2>Información Detallada</h2>
</div>

<div class="card" style="padding: 2.5rem; margin-bottom: 2rem;">
    <div style="display: flex; justify-content: space-between; align-items: flex-start; border-bottom: 1px solid var(--border-color); padding-bottom: 1.5rem; margin-bottom: 2rem;">
        <div>
            <h1 class="font-xl" style="font-size: 2.25rem; font-family: var(--font-display); margin-bottom: 0.5rem;">@Model!.Name</h1>
            <p style="color: var(--accent-primary); font-weight: 600; font-size: 14px; margin: 0;">Código de Registro: @Model!.Code (@Model!.Code2)</p>
        </div>
        <div>
            <!-- Real Flag Image Card Container -->
            <div style="border: 1px solid var(--border-color); border-radius: var(--border-radius-md); padding: 4px; background: var(--bg-primary); width: 140px; height: 90px; display: flex; align-items: center; justify-content: center; overflow: hidden;">
                @if (!string.IsNullOrEmpty(flagUrl))
                {
                    <img src="@flagUrl" alt="Bandera de @Model!.Name" style="max-width: 100%; max-height: 100%; object-fit: contain;" onerror="handleFlagError(this, 'md');" />
                }
                else
                {
                    <img src="data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='140' height='90' viewBox='0 0 140 90'><rect width='100%' height='100%' fill='%23edeae4'/><text x='50%' y='55%' font-family='sans-serif' font-size='16' fill='%238d8a80' text-anchor='middle' dominant-baseline='middle'>N/D</text></svg>" alt="" style="max-width: 100%; max-height: 100%; object-fit: contain;" />
                }
            </div>
        </div>
    </div>

    <div class="form-grid" style="display: grid; grid-template-columns: repeat(12, 1fr); gap: 1.25rem; margin-bottom: 2rem;">
        <div style="grid-column: span 4;">
            <span style="font-size: 11px; text-transform: uppercase; color: var(--ink-secondary); display: block; margin-bottom: 4px;">Continente</span>
            <strong style="font-size: 1.15rem; color: var(--ink-primary);">@TraducirContinente(Model!.Continent)</strong>
        </div>
        <div style="grid-column: span 4;">
            <span style="font-size: 11px; text-transform: uppercase; color: var(--ink-secondary); display: block; margin-bottom: 4px;">Región</span>
            <strong style="font-size: 1.15rem; color: var(--ink-primary);">@Model!.Region</strong>
        </div>
        <div style="grid-column: span 4;">
            <span style="font-size: 11px; text-transform: uppercase; color: var(--ink-secondary); display: block; margin-bottom: 4px;">Población</span>
            <strong style="font-size: 1.15rem; color: var(--ink-primary);">@Model!.Population.ToString("N0") hab.</strong>
        </div>
        <div style="grid-column: span 4; margin-top: 1rem;">
            <span style="font-size: 11px; text-transform: uppercase; color: var(--ink-secondary); display: block; margin-bottom: 4px;">Esperanza de Vida</span>
            <strong style="font-size: 1.15rem; color: var(--ink-primary);">@(Model!.LifeExpectancy.HasValue ? Model!.LifeExpectancy.Value.ToString("F1") + " Años" : "N/D")</strong>
        </div>
        <div style="grid-column: span 8; margin-top: 1rem;">
            <span style="font-size: 11px; text-transform: uppercase; color: var(--ink-secondary); display: block; margin-bottom: 4px;">Forma de Gobierno</span>
            <strong style="font-size: 1.15rem; color: var(--ink-primary);">@Model!.GovernmentForm</strong>
        </div>
    </div>
</div>

<div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 2rem; margin-bottom: 2rem;">
    <div class="card">
        <h3 class="card-title">Ciudades</h3>
        @if (Model!.Cities == null || !Model.Cities.Any())
        {
            <p style="color: var(--ink-muted); font-style: italic; font-size: var(--font-sm);">No hay ciudades registradas.</p>
        }
        else
        {
            <ul style="padding-left: 1.25rem; margin: 0; color: var(--ink-primary); list-style-type: square;">
                @foreach (var city in Model.Cities)
                {
                    <li style="margin-bottom: 0.5rem;">
                        <strong>@city.Name</strong> - @city.Population.ToString("N0") hab.
                    </li>
                }
            </ul>
        }
    </div>

    <div class="card">
        <h3 class="card-title">Idiomas Oficiales y Secundarios</h3>
        @if (Model!.CountryLanguages == null || !Model.CountryLanguages.Any())
        {
            <p style="color: var(--ink-muted); font-style: italic; font-size: var(--font-sm);">No hay idiomas registrados.</p>
        }
        else
        {
            <ul style="padding-left: 1.25rem; margin: 0; color: var(--ink-primary); list-style-type: square;">
                @foreach (var lang in Model.CountryLanguages)
                {
                    <li style="margin-bottom: 0.5rem;">
                        <strong>@lang.Language</strong> - @lang.Percentage.ToString("F1")% 
                        @if (lang.IsOfficial)
                        {
                            <span class="badge badge-success" style="font-size: 10px; margin-left: 6px; padding: 2px 6px;">Oficial</span>
                        }
                    </li>
                }
            </ul>
        }
    </div>
</div>

<div style="display: flex; justify-content: flex-end;">
    <a asp-action="Index" class="btn btn-secondary">Volver al listado</a>
</div>