@model gestionpaises.Models.Country

@{
    ViewData["Title"] = "Editar país";
}

<h1>Editar país</h1>

<form asp-action="Edit" method="post" enctype="multipart/form-data">
    <input type="hidden" asp-for="Code" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="form-group mb-3">
        <label class="form-label">Código</label>
        <input value="@Model.Code" class="form-control" disabled />
    </div>

    <div class="form-group mb-3">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="Continent" class="form-label"></label>
        <select asp-for="Continent" class="form-select">
            <option value="Asia">Asia</option>
            <option value="Europe">Europe</option>
            <option value="North America">North America</option>
            <option value="Africa">Africa</option>
            <option value="Oceania">Oceania</option>
            <option value="Antarctica">Antarctica</option>
            <option value="South America">South America</option>
        </select>
        <span asp-validation-for="Continent" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="Region" class="form-label"></label>
        <input asp-for="Region" class="form-control" />
        <span asp-validation-for="Region" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="Population" class="form-label"></label>
        <input asp-for="Population" class="form-control" />
        <span asp-validation-for="Population" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="LocalName" class="form-label"></label>
        <input asp-for="LocalName" class="form-control" />
        <span asp-validation-for="LocalName" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="GovernmentForm" class="form-label"></label>
        <input asp-for="GovernmentForm" class="form-control" />
        <span asp-validation-for="GovernmentForm" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="Code2" class="form-label"></label>
        <input asp-for="Code2" class="form-control" maxlength="2" />
        <span asp-validation-for="Code2" class="text-danger"></span>
    </div>

    @if (!string.IsNullOrEmpty(Model.BanderaPath))
    {
        <div class="mb-3">
            <label class="form-label d-block">Bandera actual</label>
            <img src="~/uploads/banderas/@Model.BanderaPath" alt="Bandera actual" style="max-height:80px;" />
        </div>
    }

    <div class="form-group mb-3">
        <label for="bandera" class="form-label">Cambiar bandera (opcional)</label>
        <input type="file" name="bandera" id="bandera" class="form-control" accept=".jpg,.jpeg,.png,.gif" />
        <span class="text-danger">@ViewData.ModelState["BanderaPath"]?.Errors.FirstOrDefault()?.ErrorMessage</span>
    </div>

    <button type="submit" class="btn btn-primary">Guardar cambios</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>